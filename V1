<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Silent Scope: Redprint (Mobile)</title>
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover,user-scalable=no" />
  <meta name="theme-color" content="#0a0a0a" />
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body {
      background: #0a0a0a;
      color: #f1f1f1;
      font-family: "Courier New", monospace;
      -webkit-tap-highlight-color: transparent;
    }

    /* Mobile ergonomics */
    select, textarea, input {
      font-size: 16px; /* prevents iOS zoom */
      transition: border-color 0.2s ease;
    }
    select:focus, textarea:focus, input:focus {
      border-color: #ff3b3b !important;
      outline: none;
    }

    .big-btn {
      font-size: 1.05rem;
      padding: 1.05rem 0;
      border-radius: 0.6rem;
      transition: all 0.15s ease;
      cursor: pointer;
      user-select: none;
    }
    .big-btn:active { transform: scale(0.97); }
    .type-btn.active {
      border: 2px solid #ff3b3b !important;
      background: #1a0000;
    }

    .chip {
      font-size: 0.75rem;
      padding: 0.55rem 0.75rem;
      border-radius: 999px;
      transition: all 0.15s ease;
      user-select: none;
    }
    .chip.active {
      background: #dc2626;
      border-color: #dc2626;
      color: #fff;
    }

    textarea {
      resize: none;
      overflow: hidden;
      min-height: 72px;
    }

    #outputBox {
      min-height: 160px;
      border-radius: 0.75rem;
      white-space: pre-wrap;
      word-break: break-word;
      line-height: 1.35;
    }

    .pulse-once { animation: pulse 0.3s ease; }
    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.03); }
    }

    .fade-in {
      animation: fadeIn 0.3s ease-in;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>

<body class="p-3 max-w-md mx-auto">

  <!-- Header -->
  <div class="flex items-center justify-between mb-4">
    <div>
      <div class="text-lg font-bold tracking-wider">
        REDPRINT <span class="text-red-500">MOBILE</span>
      </div>
      <div class="text-[10px] text-zinc-500 uppercase">Idea → Professional Brief → Copy</div>
    </div>
    <button type="button" id="clearBtn"
      class="text-xs text-zinc-400 border border-zinc-800 px-3 py-2 rounded-lg active:scale-95"
      onclick="clearAll()">
      CLEAR
    </button>
  </div>

  <!-- Mode + Output toggles -->
  <div class="mb-3">
    <div class="text-xs text-red-400 uppercase mb-2">Template Mode</div>
    <div class="flex flex-wrap gap-2">
      <button type="button" class="chip border border-zinc-700 text-zinc-200"
        onclick="setTemplate('quick', this)">Quick Prototype</button>
      <button type="button" class="chip border border-zinc-700 text-zinc-200"
        onclick="setTemplate('production', this)">Production</button>
      <button type="button" class="chip border border-zinc-700 text-zinc-200"
        onclick="setTemplate('collab', this)">Collaboration</button>
    </div>
  </div>

  <div class="mb-4">
    <div class="text-xs text-red-400 uppercase mb-2">Output</div>
    <div class="flex gap-2">
      <button type="button" class="chip border border-zinc-700 text-zinc-200 flex-1"
        onclick="setOutputMode('prompt', this)">AI Prompt</button>
      <button type="button" class="chip border border-zinc-700 text-zinc-200 flex-1"
        onclick="setOutputMode('json', this)">JSON</button>
    </div>
  </div>

  <!-- Form -->
  <form id="briefForm" class="space-y-3" onsubmit="event.preventDefault(); return false;">

    <div>
      <div class="text-xs text-red-400 uppercase mb-2">Type</div>
      <div class="flex gap-2">
        <button type="button" class="big-btn type-btn flex-1 border border-zinc-800"
          onclick="setField('type','Game', this)">Game</button>
        <button type="button" class="big-btn type-btn flex-1 border border-zinc-800"
          onclick="setField('type','Tool', this)">Tool</button>
        <button type="button" class="big-btn type-btn flex-1 border border-zinc-800"
          onclick="setField('type','Web', this)">Web</button>
      </div>
    </div>

    <!-- Main Input -->
    <div>
      <div class="text-xs text-red-400 uppercase mb-2">Core Concept</div>
      <textarea id="conceptInput" 
        class="w-full bg-zinc-900 border border-zinc-800 rounded-lg p-3 text-zinc-300 placeholder-zinc-700 focus:border-red-500"
        placeholder="e.g. A tinder-style app for adopting shelter cats..."
        oninput="autoResize(this)"></textarea>
    </div>

    <!-- Generate Action -->
    <button type="button" onclick="generate()" 
      class="w-full bg-red-600 hover:bg-red-500 text-white font-bold py-4 rounded-lg mt-2 shadow-lg shadow-red-900/20 active:scale-95 transition-transform tracking-widest">
      GENERATE BLUEPRINT
    </button>

  </form>

  <!-- Output Section -->
  <div id="outputContainer" class="hidden mt-8 mb-10 fade-in">
    <div class="flex justify-between items-end mb-2 px-1">
      <span class="text-[10px] text-zinc-500 uppercase tracking-widest">Generated Output</span>
      <button type="button" onclick="copyOutput()" class="text-xs text-red-400 font-bold active:text-white transition-colors">
        [ COPY TO CLIPBOARD ]
      </button>
    </div>
    <div id="outputBox" class="bg-zinc-900 border border-zinc-800 p-4 text-xs text-zinc-400 font-mono overflow-x-auto"></div>
  </div>

  <script>
    // Application State
    const state = {
      template: 'quick',
      outputMode: 'prompt',
      type: 'Game',
      concept: ''
    };

    // Initialize Default UI States
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelector('button[onclick*="quick"]').classList.add('active');
      document.querySelector('button[onclick*="prompt"]').classList.add('active');
      document.querySelector('button[onclick*="Game"]').classList.add('active');
    });

    // UI State Management Functions
    function setTemplate(mode, el) {
      state.template = mode;
      updateActiveState(el, 'chip', el.parentElement);
    }

    function setOutputMode(mode, el) {
      state.outputMode = mode;
      updateActiveState(el, 'chip', el.parentElement);
    }

    function setField(key, val, el) {
      state[key] = val;
      updateActiveState(el, 'type-btn', el.parentElement);
    }

    function updateActiveState(activeEl, className, parent) {
      const siblings = parent.querySelectorAll('.' + className);
      siblings.forEach(btn => btn.classList.remove('active'));
      activeEl.classList.add('active');
    }

    function autoResize(textarea) {
      textarea.style.height = 'auto';
      textarea.style.height = textarea.scrollHeight + 'px';
      state.concept = textarea.value;
    }

    function clearAll() {
      const conceptInput = document.getElementById('conceptInput');
      const outputContainer = document.getElementById('outputContainer');
      const outputBox = document.getElementById('outputBox');
      
      conceptInput.value = '';
      conceptInput.style.height = 'auto';
      outputContainer.classList.add('hidden');
      outputBox.innerText = '';
      state.concept = '';
    }

    // Core Generation Logic
    function generate() {
      const concept = document.getElementById('conceptInput').value.trim();
      if (!concept) {
        alert("Please enter a core concept to generate your blueprint.");
        return;
      }

      const outputContainer = document.getElementById('outputContainer');
      const outputBox = document.getElementById('outputBox');
      
      let result = "";

      if (state.outputMode === 'json') {
        result = generateJSON(concept);
      } else {
        result = generatePrompt(concept);
      }

      outputBox.innerText = result;
      outputContainer.classList.remove('hidden');
      
      // Smooth scroll to results
      setTimeout(() => {
        outputContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 100);
    }

    function generateJSON(concept) {
      const data = {
        project_name: `${state.type} Project: ${concept.substring(0, 50)}${concept.length > 50 ? '...' : ''}`,
        type: state.type,
        template_level: state.template,
        core_concept: concept,
        generated_at: new Date().toISOString(),
        estimated_complexity: state.template === 'quick' ? 'Low' : state.template === 'production' ? 'High' : 'Medium',
        suggested_features: getSuggestedFeatures(state.type),
        next_steps: getNextSteps(state.template)
      };
      return JSON.stringify(data, null, 2);
    }

    function generatePrompt(concept) {
      const templates = {
        quick: `Create a high-level MVP specification for a ${state.type} application based on this concept: "${concept}"

Focus on:
• Core features that define the MVP
• Basic user flow
• Essential technical requirements
• Success metrics

Keep it concise and actionable for rapid prototyping.`,

        production: `Act as a Senior Product Manager. Write a comprehensive Product Requirements Document (PRD) for a ${state.type} application.

**Core Concept:** "${concept}"

**Required Structure:**
1. **Executive Summary** - Vision, goals, and business case
2. **User Personas** - Target audience analysis
3. **Functional Requirements** - Detailed feature specifications
4. **Technical Architecture** - Stack recommendations and scalability considerations
5. **User Experience** - Key user journeys and interaction design
6. **Success Metrics** - KPIs and measurement strategy
7. **Risk Assessment** - Potential challenges and mitigation strategies
8. **Timeline & Milestones** - Development phases and deliverables

Provide detailed, production-ready specifications suitable for a development team.`,

        collab: `Create a comprehensive project brief for a cross-functional team developing a ${state.type} application.

**Project Concept:** "${concept}"

**Team Structure & Responsibilities:**
• **Design Team** - UX/UI requirements and deliverables
• **Development Team** - Technical implementation and architecture
• **Marketing Team** - Go-to-market strategy and user acquisition
• **Product Team** - Feature prioritization and roadmap

**Sprint Planning:**
• Sprint 0: Discovery and planning
• Sprint 1-2: Core functionality
• Sprint 3-4: Polish and testing
• Sprint 5: Launch preparation

**Communication Framework:**
• Daily standups and sprint reviews
• Weekly cross-team alignment meetings
• Milestone demonstrations and feedback sessions

Include specific role definitions, deliverable timelines, and success criteria for each team.`
      };

      return templates[state.template] || templates['quick'];
    }

    function getSuggestedFeatures(type) {
      const features = {
        Game: ['Player progression', 'Leaderboards', 'Social features', 'In-app purchases'],
        Tool: ['User authentication', 'Data export', 'Collaboration features', 'Analytics dashboard'],
        Web: ['Responsive design', 'SEO optimization', 'User accounts', 'Content management']
      };
      return features[type] || ['User interface', 'Core functionality', 'Data management'];
    }

    function getNextSteps(template) {
      const steps = {
        quick: ['Create wireframes', 'Set up development environment', 'Build core features', 'User testing'],
        production: ['Stakeholder approval', 'Technical architecture review', 'Development sprint planning', 'QA strategy'],
        collab: ['Team kickoff meeting', 'Role assignment', 'Communication setup', 'Sprint 0 planning']
      };
      return steps[template] || steps['quick'];
    }

    function copyOutput() {
      const text = document.getElementById('outputBox').innerText;
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.querySelector('#outputContainer button');
        const originalText = btn.innerText;
        btn.innerText = "COPIED!";
        btn.classList.add('text-green-500');
        setTimeout(() => {
          btn.innerText = originalText;
          btn.classList.remove('text-green-500');
        }, 2000);
      }).catch(() => {
        // Fallback for older browsers
        const textArea = document.createElement('textarea');
        textArea.value = text;
        document.body.appendChild(textArea);
        textArea.select();
        document.execCommand('copy');
        document.body.removeChild(textArea);
      });
    }
  </script>
</body>
</html>
